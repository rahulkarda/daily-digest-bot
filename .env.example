# Required — get from https://aistudio.google.com/app/apikey (free, no billing)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail credentials
# GMAIL_USER: your full Gmail address
# GMAIL_APP_PASSWORD: 16-char app password from Google Account → Security → 2-Step → App passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Who to send the digest to (defaults to GMAIL_USER if not set)
DIGEST_TO=you@gmail.com

# Time to send the digest daily (24-hour format, local time, default: 08:00)
SEND_TIME=08:00

# Set to "true" to also save a digest-preview.html file each run
SAVE_HTML=false
